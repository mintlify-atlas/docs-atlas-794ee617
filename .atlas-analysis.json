  "keyFeatures": [
    "RSA blind signature protocol ensuring administrator cannot link voter identity to ballot content",
    "Two-factor nonce credential system (N1 + N2) for voter authentication and anonymization",
    "Anonymizer pipeline that decouples voter identity from submitted encrypted ballots",
    "Counter service that decrypts, verifies signatures, and tallies votes with full audit trail",
    "Session-based N1 verification preventing double voting",
    "Gmail API integration for secure credential delivery via email",
    "Alembic-managed PostgreSQL migrations for reproducible database schema",
    "Automatic vote finalization when all registered voters have submitted ballots"
  ],
  "publicApiSurface": [
    "POST /voters/register",
    "POST /voters/check_n1",
    "POST /voters/submit_vote",
    "POST /voting/start-vote",
    "POST /voting/end-vote",
    "GET /voting/vote-status",
    "GET /results/tally",
    "POST /results/verify-vote",
    "GET /config/voting-system-config",
    "PATCH /config/voting-system-config",
    "GET /health"
  ]
