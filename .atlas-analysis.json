  "projectType": "api-service",
  "projectName": "Crypto E-Voting API",
  "projectDescription": "A FastAPI-based back-end for a cryptographic electronic voting system that uses RSA blind signatures, nonce-based credentials, and an anonymizer pipeline to ensure voter privacy and ballot integrity.",
